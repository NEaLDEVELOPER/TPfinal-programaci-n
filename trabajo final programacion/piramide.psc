Proceso Piramide
	
    Definir altura, fila, numero, espacio Como Entero
	
    Escribir "Ingrese la altura:"
    Leer altura
	
    Para fila <- 1 Hasta altura Hacer
		
        Para espacio <- 1 Hasta altura - fila Hacer
            Escribir Sin Saltar " "
        FinPara
		
        Para numero <- 1 Hasta fila Hacer
            Escribir Sin Saltar numero
        FinPara
		
        Escribir ""
		
    FinPara
	
FinProceso